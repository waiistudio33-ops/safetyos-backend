generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id          String   @id @default(uuid())
  full_name   String
  department  String
  role        String
  status      String   @default("ACTIVE")
  profile_url String?
  created_at  DateTime @default(now())
  username    String?  @unique
  password    String?
  line_id     String?  @unique

  approvals        ApprovalLog[]
  bbs_observations BbsObservation[]
  certificates     Certificate[]
  equipment_logs   EquipmentInspectionLog[]
  incident_reports IncidentReport[]
  training_records TrainingRecord[]

  // เชื่อมกับตาราง Permit V2
  permits permits_v2[]
}

// ==========================================
// 📋 [NEW] ระบบ E-Permit V2 (Enterprise Schema)
// ==========================================
model permits_v2 {
  id              String   @id @default(uuid())
  permit_number   String   @unique
  title           String
  description     String?
  permit_type     String
  status          String   @default("PENDING_AREA_OWNER")
  location_detail String
  start_time      DateTime
  end_time        DateTime
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  // ข้อมูลผู้ขออนุญาต และ ผู้รับเหมา (ครบตามฟอร์ม)
  applicant_id          String?
  applicant_phone       String? // เบอร์โทรศัพท์
  contractor_company    String? // บริษัทผู้รับเหมา
  contractor_supervisor String? // หัวหน้างานผู้รับเหมา
  project_manager       String? // ผู้จัดการโครงการ

  extension_reason String?

  // ฟิลด์ JSON สำหรับเก็บข้อมูลที่ยืดหยุ่นได้ (Checklists)
  work_sub_type   Json? // เช่น ["เจียร/ตัด", "เชื่อมไฟฟ้า"]
  tools_equipment Json? // เครื่องมือที่ใช้ (เก็บเป็น Array หรือ Object)
  safety_measures Json? // มาตรการที่ติ๊กเลือก (เช่น กั้นพื้นที่, ติดป้ายเตือน)
  ppe_required    Json? // PPE ที่ติ๊กเลือก (หมวก, รองเท้า, SCBA)
  attached_docs   Json? // เช็คลิสต์เอกสารแนบ เช่น {"jsa": true, "sds": "Benzene"}

  // สำหรับการปิดงาน (Closing)
  is_closed       Boolean   @default(false)
  closeout_status String? // เช่น "SAFE", "RISKY"
  closeout_note   String? // สาเหตุถ้ามีความเสี่ยง
  closed_at       DateTime?

  // ความสัมพันธ์ (Relations)
  applicant         User?                   @relation(fields: [applicant_id], references: [id])
  hazard_details    permit_hazard_details[]
  gas_logs          permit_gas_logs[]
  approval_logs     ApprovalLog[]
  attachments       PermitAttachment[]
  confined_entries  ConfinedSpaceEntry[]
  loto_records      loto_records_v2[]
  workers           PermitWorker[] // 🟢 รายชื่อผู้ปฏิบัติงาน
  daily_inspections PermitDailyInspection[] // 🟢 ตรวจสอบความปลอดภัยรายวัน
  extensions        PermitExtension[] // 🟢 ประวัติการขอต่อเวลา
}

// 🟢 [NEW] ตารางเก็บรายชื่อผู้ปฏิบัติงาน (หน้า 1 ของทุกฟอร์ม)
model PermitWorker {
  id          String @id @default(uuid())
  permit_id   String
  worker_name String

  permit permits_v2 @relation(fields: [permit_id], references: [id], onDelete: Cascade)
}

// 🟢 [NEW] ตารางตรวจสอบการปฏิบัติงานประจำวัน (หน้า 2 ฟอร์ม Hot Work)
model PermitDailyInspection {
  id                   String   @id @default(uuid())
  permit_id            String
  inspection_date      DateTime // วันที่ตรวจ
  electrical_checked   Boolean  @default(false)
  gas_cylinder_checked Boolean  @default(false)
  fire_equip_checked   Boolean  @default(false)
  ppe_checked          Boolean  @default(false)
  other_notes          String?
  inspector_name       String?

  permit permits_v2 @relation(fields: [permit_id], references: [id], onDelete: Cascade)
}

// 🟢 [NEW] ตารางการขอต่ออายุใบอนุญาตทำงาน
model PermitExtension {
  id             String   @id @default(uuid())
  permit_id      String
  request_date   DateTime @default(now())
  new_start_time DateTime
  new_end_time   DateTime
  action_details String? // รายละเอียดการดำเนินงาน
  applicant_name String?
  approver_name  String?

  permit permits_v2 @relation(fields: [permit_id], references: [id], onDelete: Cascade)
}

model permit_hazard_details {
  permit_id           String  @id
  supervisor_name     String?
  gas_tester_name     String?
  standby_person_name String?

  // สำหรับงานที่สูง (Work at Height)
  height_level Float? // ความสูง (เมตร)

  // สำหรับงานอับอากาศ (Confined Space)
  rescuer_name         String? // ผู้ช่วยเหลือ (Rescuer)
  communication_method String? // ช่องทางสื่อสารกับทีมช่วยเหลือ

  // อุปกรณ์ดับเพลิง
  fire_extinguisher Json? // เช่น { required: true, type: "CO2", amount: 2 }

  rescue_plan_url      String?
  is_med_cert_verified Boolean @default(false)
  is_loto_required     Boolean @default(false)

  permit permits_v2 @relation(fields: [permit_id], references: [id], onDelete: Cascade)
}

model permit_gas_logs {
  id             String   @id @default(uuid())
  permit_id      String
  o2_level       Float?
  lel_level      Float?
  co_level       Float?
  h2s_level      Float?
  recorded_at    DateTime @default(now())
  inspector_name String?

  permit permits_v2 @relation(fields: [permit_id], references: [id], onDelete: Cascade)
}

model loto_records_v2 {
  id              String   @id @default(uuid())
  permit_id       String
  isolation_point String // จุดตัดแยกพลังงาน
  energy_type     String // ประเภทพลังงาน (ELECTRICAL, MECHANICAL, ฯลฯ)
  lock_number     String // หมายเลขแม่กุญแจ
  is_verified     Boolean  @default(false)
  verified_by     String?
  created_at      DateTime @default(now())

  permit permits_v2 @relation(fields: [permit_id], references: [id], onDelete: Cascade)
}

model PermitAttachment {
  id           String   @id @default(uuid())
  permit_id    String
  file_name    String
  file_type    String
  storage_path String
  public_url   String
  uploaded_at  DateTime @default(now())

  permit permits_v2 @relation(fields: [permit_id], references: [id], onDelete: Cascade)
}

model ApprovalLog {
  id          String   @id @default(uuid())
  permit_id   String
  approver_id String
  action      String
  comment     String?
  created_at  DateTime @default(now())

  approver User       @relation(fields: [approver_id], references: [id])
  permit   permits_v2 @relation(fields: [permit_id], references: [id], onDelete: Cascade)
}

model ConfinedSpaceEntry {
  id           String   @id @default(uuid())
  permit_id    String
  worker_name  String
  time_in      DateTime
  time_out     DateTime?
  status       String
  role         String?  // 🟢 เติมบรรทัดนี้เข้าไปครับ (เครื่องหมาย ? คือยอมให้เป็นค่าว่างได้)
  
  permit permits_v2 @relation(fields: [permit_id], references: [id], onDelete: Cascade)
}

// ==========================================
// 🎓 MODULE: ระบบอบรม & ใบรับรอง
// ==========================================
model Certificate {
  id          String   @id @default(uuid())
  user_id     String
  cert_name   String
  file_url    String
  issued_date DateTime
  expiry_date DateTime
  status      String   @default("PENDING")
  created_at  DateTime @default(now())
  user        User     @relation(fields: [user_id], references: [id])
}

model Course {
  id            String           @id @default(uuid())
  title         String
  description   String?
  video_url     String?
  passing_score Int              @default(80)
  thumbnail     String?
  duration      String?
  created_at    DateTime         @default(now())
  records       TrainingRecord[]
  questions     ExamQuestion[]
}

model ExamQuestion {
  id         String   @id @default(uuid())
  course_id  String
  course     Course   @relation(fields: [course_id], references: [id], onDelete: Cascade)
  question   String
  choices    Json
  answer     String
  created_at DateTime @default(now())
}

model TrainingRecord {
  id           String   @id @default(uuid())
  user_id      String
  course_id    String
  score        Int
  passed       Boolean
  completed_at DateTime @default(now())
  course       Course   @relation(fields: [course_id], references: [id])
  user         User     @relation(fields: [user_id], references: [id])
}

// ==========================================
// ⚠️ MODULE: ระบบแจ้งจุดเสี่ยง (Incident Report)
// ==========================================
model IncidentReport {
  id          String   @id @default(uuid())
  reporter_id String
  title       String
  description String
  type        String
  lat         Float?
  lng         Float?
  image_url   String?
  status      String   @default("OPEN")
  created_at  DateTime @default(now())
  reporter    User     @relation(fields: [reporter_id], references: [id])
}

// ==========================================
// 🌟 MODULE: ระบบตรวจอุปกรณ์ (Equipment)
// ==========================================
model Equipment {
  id      String                   @id @default(uuid())
  qr_code String                   @unique
  name    String
  type    String
  status  String                   @default("NORMAL")
  logs    EquipmentInspectionLog[]
}

model EquipmentInspectionLog {
  id           String    @id @default(uuid())
  equipment_id String
  inspector_id String
  status       String
  details      String
  created_at   DateTime  @default(now())
  equipment    Equipment @relation(fields: [equipment_id], references: [id])
  inspector    User      @relation(fields: [inspector_id], references: [id])
}

// ==========================================
// 👁️ MODULE: BBS Observation
// ==========================================
model BbsObservation {
  id             String        @id @default(uuid())
  date           DateTime      @default(now())
  location       String
  observed_group ObservedGroup @default(EMPLOYEE)
  behavior_type  BehaviorType
  category       BbsCategory
  action_taken   ActionTaken
  description    String
  root_cause     RootCause?
  suggestion     String?
  photos         String[]
  observer_id    String
  created_at     DateTime      @default(now())
  updated_at     DateTime      @updatedAt
  observer       User          @relation(fields: [observer_id], references: [id])
}

enum ObservedGroup {
  EMPLOYEE
  CONTRACTOR
}

enum BehaviorType {
  SAFE
  UNSAFE
}

enum BbsCategory {
  PPE
  TOOLS
  POSTURE
  HOUSEKEEPING
  LINE_OF_FIRE
  PROCEDURE
}

enum ActionTaken {
  PRAISED
  CORRECTED
  VERBAL_WARNING
  STOP_WORK
}

enum RootCause {
  RUSH
  UNAWARE
  EQUIPMENT
  HABIT
}
