generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==========================================
// 👤 MODULE: ระบบผู้ใช้งาน (User Management)
// ==========================================
model User {
  id                String    @id @default(uuid())
  employee_id       String?  @unique
  full_name         String
  department        String
  role              String
  status            String    @default("ACTIVE")
  profile_url       String?
  username          String?   @unique
  password          String?
  line_id           String?   @unique
  email             String?
  phone             String?
  created_at        DateTime  @default(now())

  // 🏥 ข้อมูลทางการแพทย์และฉุกเฉิน
  blood_group       String?   @default("ไม่ระบุ")
  medical_cond      String?   @default("ไม่มี")
  fit_to_work_date  DateTime?
  emergency_contact String?

  // 🔗 ความสัมพันธ์ (Relations)
  permits           permits_v2[]
  approvals         ApprovalLog[]
  bbs_observations  BbsObservation[]
  certificates      Certificate[]
  equipment_logs    EquipmentInspectionLog[]
  incident_reports  IncidentReport[]
  training_records  TrainingRecord[]
}


// ==========================================
// 📋 MODULE: ระบบขออนุญาตทำงาน (E-Permit V2)
// ==========================================
model permits_v2 {
  id                    String    @id @default(uuid())
  permit_number         String    @unique
  title                 String    // 🟢 เก็บค่า "ความประสงค์จะขออนุญาตทำงาน"
  description           String?
  permit_type           String
  status                String    @default("PENDING_AREA_OWNER")
  location_detail       String
  
  // 🟢 ฟิลด์ใหม่ตามฟอร์ม Step 1
  area_owner_name       String?   // ชื่อเจ้าของงาน
  owner_department      String?   // หน่วยงานเจ้าของพื้นที่
  machinery_tools       String?   // เครื่องจักรหรือเครื่องมือหลักที่ใช้
  jsa_agreement         Boolean   @default(false) // ยืนยันการแนบ JSA

  // 🗄️ การจัดเก็บและลบเอกสารอัตโนมัติ (Data Archiving)
  archive_id            String?   @unique   // Tag ID อ้างอิง
  archive_status        String    @default("NONE") // NONE, PENDING_ARCHIVE, ARCHIVED
  archive_url           String?             // ลิงก์ Google Drive
  archived_at           DateTime?           // เวลาที่เก็บ

  // 🕒 ข้อมูลเวลาปฏิบัติงาน
  start_time            DateTime
  end_time              DateTime
  work_shift            String?   // กะการทำงาน (MORNING / NIGHT)
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt

  // 👷 ข้อมูลผู้ขออนุญาต (ตัดข้อมูลที่ดึงจาก User Profile ออก เพื่อลดความซ้ำซ้อน)
  applicant_id          String?
  extension_reason      String?

  // 📝 Checklists (JSON Fields)
  work_sub_type         Json?
  tools_equipment       Json?
  safety_measures       Json?
  ppe_required          Json?
  document_checklist    Json?     
  other_documents_text  String?   // 🟢 เก็บรายชื่อเอกสารอื่นๆ เป็น String (เช่น "Lifting Plan, Load Chart")
  attached_docs         Json?     

  // 🛑 การปิดงาน (Closing)
  is_closed             Boolean   @default(false)
  closeout_status       String?
  closeout_note         String?
  closed_at             DateTime?

  // 🔗 ความสัมพันธ์ (Relations)
  applicant             User?                   @relation(fields: [applicant_id], references: [id])
  hazard_details        permit_hazard_details[]
  gas_logs              permit_gas_logs[]
  approval_logs         ApprovalLog[]
  attachments           PermitAttachment[]
  confined_entries      ConfinedSpaceEntry[]
  loto_records          loto_records_v2[]
  workers               PermitWorker[]
  daily_inspections     PermitDailyInspection[]
  extensions            PermitExtension[]
}

// 🟢 อัปเกรดตารางรายชื่อผู้ปฏิบัติงานให้ครบเป๊ะตามฟอร์ม
model PermitWorker {
  id            String     @id @default(uuid())
  permit_id     String
  worker_name   String
  company       String?    // บริษัท
  card_type     String?    // ประเภทบัตร (CONTRACTOR, VISITOR)
  card_number   String?    // เลขที่บัตร
  access_area   String?    // Access Card (Area)
  access_number String?    // Access Card (Number)
  
  permit        permits_v2 @relation(fields: [permit_id], references: [id], onDelete: Cascade)
}

model PermitDailyInspection {
  id                   String     @id @default(uuid())
  permit_id            String
  inspection_date      DateTime
  electrical_checked   Boolean    @default(false)
  gas_cylinder_checked Boolean    @default(false)
  fire_equip_checked   Boolean    @default(false)
  ppe_checked          Boolean    @default(false)
  other_notes          String?
  inspector_name       String?
  permit               permits_v2 @relation(fields: [permit_id], references: [id], onDelete: Cascade)
}

model PermitExtension {
  id             String     @id @default(uuid())
  permit_id      String
  request_date   DateTime   @default(now())
  new_start_time DateTime
  new_end_time   DateTime
  action_details String?
  applicant_name String?
  approver_name  String?
  permit         permits_v2 @relation(fields: [permit_id], references: [id], onDelete: Cascade)
}

model permit_hazard_details {
  permit_id            String     @id
  supervisor_name      String?
  gas_tester_name      String?
  standby_person_name  String?
  height_level         Float?
  rescuer_name         String?
  communication_method String?
  fire_extinguisher    Json?
  rescue_plan_url      String?
  is_med_cert_verified Boolean    @default(false)
  is_loto_required     Boolean    @default(false)
  permit               permits_v2 @relation(fields: [permit_id], references: [id], onDelete: Cascade)
}

model permit_gas_logs {
  id               String     @id @default(uuid())
  permit_id        String
  o2_level         Float?
  lel_level        Float?
  co_level         Float?
  h2s_level        Float?
  recorded_at      DateTime   @default(now())
  inspector_name   String?
  safety_talk_done Boolean    @default(false) 
  permit           permits_v2 @relation(fields: [permit_id], references: [id], onDelete: Cascade)
}

model loto_records_v2 {
  id              String     @id @default(uuid())
  permit_id       String
  isolation_point String
  energy_type     String
  lock_number     String
  is_verified     Boolean    @default(false)
  verified_by     String?
  created_at      DateTime   @default(now())
  permit          permits_v2 @relation(fields: [permit_id], references: [id], onDelete: Cascade)
}

model PermitAttachment {
  id           String     @id @default(uuid())
  permit_id    String
  file_name    String
  file_type    String
  storage_path String
  public_url   String
  uploaded_at  DateTime   @default(now())
  permit       permits_v2 @relation(fields: [permit_id], references: [id], onDelete: Cascade)
}

model ApprovalLog {
  id          String     @id @default(uuid())
  permit_id   String
  approver_id String
  action      String
  comment     String?
  created_at  DateTime   @default(now())
  approver    User       @relation(fields: [approver_id], references: [id])
  permit      permits_v2 @relation(fields: [permit_id], references: [id], onDelete: Cascade)
}


// ==========================================
// 🕳️ MODULE: งานในที่อับอากาศ (Confined Space)
// ==========================================
model ConfinedSpaceEntry {
  id          String     @id @default(uuid())
  permit_id   String
  worker_name String
  time_in     DateTime
  time_out    DateTime?
  status      String
  role        String?
  permit      permits_v2 @relation(fields: [permit_id], references: [id], onDelete: Cascade)
}


// ==========================================
// 🎓 MODULE: ระบบอบรม & ใบรับรอง (Training)
// ==========================================
model Certificate {
  id          String   @id @default(uuid())
  user_id     String
  cert_name   String
  file_url    String
  issued_date DateTime
  expiry_date DateTime
  status      String   @default("PENDING")
  created_at  DateTime @default(now())
  user        User     @relation(fields: [user_id], references: [id])
}

model Course {
  id            String           @id @default(uuid())
  title         String
  description   String?
  video_url     String?
  passing_score Int              @default(80)
  thumbnail     String?
  duration      String?
  created_at    DateTime         @default(now())
  records       TrainingRecord[]
  questions     ExamQuestion[]
}

model ExamQuestion {
  id         String   @id @default(uuid())
  course_id  String
  question   String
  choices    Json
  answer     String
  created_at DateTime @default(now())
  course     Course   @relation(fields: [course_id], references: [id], onDelete: Cascade)
}

model TrainingRecord {
  id           String   @id @default(uuid())
  user_id      String
  course_id    String
  score        Int
  passed       Boolean
  completed_at DateTime @default(now())
  course       Course   @relation(fields: [course_id], references: [id])
  user         User     @relation(fields: [user_id], references: [id])
}


// ==========================================
// ⚠️ MODULE: ระบบแจ้งจุดเสี่ยง (Incident Report)
// ==========================================
model IncidentReport {
  id          String         @id @default(uuid())
  reporter_id String
  title       String
  description String
  type        IncidentType   
  lat         Float?
  lng         Float?
  image_url   String?
  status      IncidentStatus @default(OPEN) 
  created_at  DateTime       @default(now())
  updated_at  DateTime       @updatedAt 
  
  // 🔗 ความสัมพันธ์
  reporter    User           @relation(fields: [reporter_id], references: [id])
}

enum IncidentType {
  NEAR_MISS          
  FIRST_AID          
  EQUIPMENT_DAMAGE   
  ENVIRONMENTAL      
  SAFETY_HAZARD      
  UNSAFE_ACT         
  UNSAFE_CONDITION   
}

enum IncidentStatus {
  OPEN               
  IN_PROGRESS        
  RESOLVED           
  CLOSED             
}

// ==========================================
// 🌟 MODULE: ระบบตรวจอุปกรณ์ (Equipment)
// ==========================================
model Equipment {
  id         String                   @id @default(uuid())
  qr_code    String                   @unique
  name       String
  type       String
  status     String                   @default("NORMAL")
  updated_at DateTime                 @default(now()) @updatedAt 
  logs       EquipmentInspectionLog[]
}

model EquipmentInspectionLog {
  id             String    @id @default(uuid())
  equipment_id   String
  inspector_id   String
  inspector_name String?   
  status         String
  details        String
  photos         Json?     
  created_at     DateTime  @default(now())
  equipment      Equipment @relation(fields: [equipment_id], references: [id])
  inspector      User      @relation(fields: [inspector_id], references: [id])
}


// ==========================================
// 👁️ MODULE: BBS Observation (สังเกตพฤติกรรม)
// ==========================================
model BbsObservation {
  id             String        @id @default(uuid())
  date           DateTime      @default(now())
  location       String
  observed_group ObservedGroup @default(EMPLOYEE)
  behavior_type  BehaviorType
  category       BbsCategory
  action_taken   ActionTaken
  description    String
  root_cause     RootCause?
  suggestion     String?
  photos         String[]
  observer_id    String
  created_at     DateTime      @default(now())
  updated_at     DateTime      @updatedAt
  observer       User          @relation(fields: [observer_id], references: [id])
}

enum ObservedGroup {
  EMPLOYEE
  CONTRACTOR
}

enum BehaviorType {
  SAFE
  UNSAFE
}

enum BbsCategory {
  PPE
  TOOLS
  POSTURE
  HOUSEKEEPING
  LINE_OF_FIRE
  PROCEDURE
}

enum ActionTaken {
  PRAISED
  CORRECTED
  VERBAL_WARNING
  STOP_WORK
}

enum RootCause {
  RUSH
  UNAWARE
  EQUIPMENT
  HABIT
}